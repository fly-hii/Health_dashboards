{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://health-dashboards-patient-backend.vercel.app/api/:path*" },
    { "source": "/socket.io/:path*", "destination": "https://health-dashboards-patient-backend.vercel.app/socket.io/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
